# Common IntelliJ Platform excludes

# User specific
**/.idea/**/workspace.xml
**/.idea/**/tasks.xml
**/.idea/shelf/*
**/.idea/dictionaries
**/.idea/httpRequests/

# Sensitive or high-churn files
**/.idea/**/dataSources/
**/.idea/**/dataSources.ids
**/.idea/**/dataSources.xml
**/.idea/**/dataSources.local.xml
**/.idea/**/sqlDataSources.xml
**/.idea/**/dynamic.xml

# Rider
# Rider auto-generates .iml files, and contentModel.xml
**/.idea/**/*.iml
**/.idea/**/contentModel.xml
**/.idea/**/modules.xml

*.suo
*.user
.vs/
[Bb]in/
[Oo]bj/
_UpgradeReport_Files/
[Pp]ackages/

.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/libraries
.idea/runConfigurations/

# Ignore build output directories
bin/
obj/

# Ignore temporary files
*.tmp
*.temp
*.bak

# Ignore NuGet packages
packages/
*.nupkg
# If using PackageReference in csproj (NuGet 4+)
**/packages/*

# Ignore local configuration files
appsettings.Development.json
appsettings.Local.json

# Ignore system files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd
*.swp
*.lock
*.pyc
*.pyo
*.orig
*.idx
*.ptp
*.class

# Ignore files generated by Rider
*.sln.iml
out/
# Ignore files generated by other IDEs
*.iml
*.ipr
*.iws

# Ignore VS Code settings (if using)
.vscode/

# Ignore generated files
Generated\ Files/

# Ignore platform-specific files for MAUI projects
# Mobile platform files
*.apk
*.ap_
*.aab
*.ipa
*.app
*.xcarchive
*.dSYM/

# Mac platform folders
bin/Debug/
bin/Release/

# Xcode project files (for iOS builds)
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
project.xcworkspace/
xcuserdata/

# Node.js dependencies (if any)
node_modules/

# Ignore secret files (if any)
*.key
*.pem
*.cert

# Ignore package lock files (if using npm)
package-lock.json
yarn.lock

# Ignore coverage reports
coverage/
*.cov

# Ignore cache files
.cache/
*.cache

# Ignore logs and reports
*.log
logs/
reports/

# Ignore temporary folders
tmp/
temp/

# Ignore MacOS specific files
.AppleDouble
.LSOverride

# Ignore other system files
$RECYCLE.BIN/
*.lnk

# DB files
*.db*
./API/Migrations/*